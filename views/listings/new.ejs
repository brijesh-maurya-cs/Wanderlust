<% layout("/layouts/boilerplate") %>
<div class="row mt-1">
    <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-2" >
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" class="form-control"  required  placeholder="Add Title">
                <div class="valid-feedback">Looks good!</div>
        </div>

        <div class="mb-2">
            <label for="descripiton" class="form-label">Descripiton</label>
            <textarea type="text" name="listing[description]" class="form-control" required  ></textarea>
             <div class="invalid-feedback">  Please Enter A Short Description</div>

        </div>

        <div class="mb-2">
    <label for="category" class="form-label">Category</label>
    <select name="listing[category]" class="form-control" required>
        <option value="">Select Category</option>
        <option value="Trending">🔥 Trending</option>
        <option value="Rooms">🛏️ Rooms</option>
        <option value="Iconic Cities">🏙️ Iconic Cities</option>
        <option value="Mountains">⛰️ Mountains</option>
        <option value="Castles">🏰 Castles</option>
        <option value="Amazing Pools">🏊 Amazing Pools</option>
        <option value="Camping">🏕️ Camping</option>
        <option value="Farms">🐄 Farms</option>
        <option value="Arctic">❄️ Arctic</option>
    </select>
    <div class="invalid-feedback">Please select a category</div>
</div>

        
        
        <div class="mb-2"> 
            <label for="image" class="form-label">Upload Image</label>
            <input type="file" name="listing[image]" class="form-control" required >

        </div>

        <div class="row">
        <div class="mb-2 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" class="form-control" type="number" required  placeholder="1200">
            <div class="invalid-feedback">
          Price Should Be Valid
      </div>

        </div>

        <div class="mb-2 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="listing[country]" class="form-control" required placeholder="India">
             <div class="invalid-feedback">  Country Should Be Valid   </div>
        </div>
        </div>

        <div class="mb-2">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" class="form-control" required placeholder="Jaipur,Rajasthan">
                 <div class="invalid-feedback">
         Location Should Be Valid
      </div>
        </div>


        <div class="text-center">
            <button class="btn btn-dark add-btn w-25 mb-3">Add</button>
        </div>
    </form>
    </div>
</div> 